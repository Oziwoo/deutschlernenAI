# Frontend (Vite) — add these in Vercel dashboard as "Environment Variables"
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
VITE_GOOGLE_API_KEY=gsk_...   # Groq API key (https://console.groq.com)

# Backend (Vercel Serverless Functions)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...   # service_role key, NOT anon key
GOOGLE_API_KEY=AIza...        # Google Gemini API key
